{
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/", "destination": "/apps/web/index.html" },
    { "source": "/categories", "destination": "/apps/web/categories.html" },
    { "source": "/search", "destination": "/apps/web/search.html" },
    { "source": "/premium", "destination": "/apps/web/premium.html" },
    { "source": "/dashboard", "destination": "/apps/web/dashboard.html" },
    { "source": "/about", "destination": "/apps/web/about.html" },
    { "source": "/contact", "destination": "/apps/web/contact.html" },
    { "source": "/tools-index.json", "destination": "/public/tools-index.json" },
    { "source": "/manifest.json", "destination": "/public/manifest.json" },
    { "source": "/tools/(.*)", "destination": "/tools/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/public/(.*)", "destination": "/public/$1" }
  ]
}
